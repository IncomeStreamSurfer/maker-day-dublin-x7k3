---
import Layout from '../layouts/Layout.astro';
export const prerender = false;
---
<Layout title="Checkout cancelled — Maker Day Dublin">
  <section class="mx-auto max-w-2xl px-6 py-24 text-center">
    <div class="display text-4xl md:text-5xl font-bold">No worries.</div>
    <p class="mt-6 text-lg opacity-80">Your card wasn't charged. Come back whenever you're ready.</p>
    <a href="/#tickets" class="btn btn-primary mt-8">Back to tickets</a>
  </section>
</Layout>
